{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebhookExtractionV1",
  "description": "Strict target schema returned by the LLM. Validated before any DB write.",
  "type": "object",
  "additionalProperties": false,
  "required": ["classification", "vendor_id", "confidence"],
  "properties": {
    "classification": {
      "type": "string",
      "enum": ["shipment", "invoice", "unclassified"]
    },
    "vendor_id": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "entity_external_id": {"type": ["string", "null"]},
    "event_type": {
      "type": ["string", "null"],
      "enum": [
        "shipment.picked_up",
        "shipment.in_transit",
        "shipment.out_for_delivery",
        "shipment.delivered",
        "shipment.exception",
        "shipment.cancelled",
        "invoice.issued",
        "invoice.paid",
        "invoice.voided",
        "invoice.refunded",
        null
      ]
    },
    "event_timestamp": {
      "type": ["string", "null"],
      "description": "ISO-8601, timezone-aware. The orchestrator additionally validates parseability."
    },
    "amount": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["currency", "amount_minor"],
      "properties": {
        "currency": {
          "type": "string",
          "minLength": 3,
          "maxLength": 3,
          "pattern": "^[A-Z]{3}$"
        },
        "amount_minor": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "due_at": {"type": ["string", "null"]},
    "reference_ids": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "linked_references": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "location": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "code": {"type": ["string", "null"]},
        "name": {"type": ["string", "null"]},
        "latitude": {"type": ["number", "null"]},
        "longitude": {"type": ["number", "null"]}
      }
    },
    "raw_milestone": {"type": ["string", "null"]},
    "raw_kind": {"type": ["string", "null"]},
    "summary": {"type": ["string", "null"]},
    "reason": {"type": ["string", "null"]}
  }
}
