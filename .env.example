# Copy to .env to override docker-compose defaults.

DATABASE_URL=postgresql://gls:gls@localhost:5432/gls
REDIS_URL=redis://localhost:6379/0

# stub | openai
LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

LOG_LEVEL=INFO

# LLM budget guards (per process)
LLM_GLOBAL_DAILY_BUDGET_USD=5.0
LLM_PER_VENDOR_DAILY_BUDGET_USD=1.0
