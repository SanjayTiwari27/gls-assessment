# Copy to .env to override docker-compose defaults.

DATABASE_URL=postgresql://gls:gls@localhost:5432/gls
REDIS_URL=redis://localhost:6379/0

# stub | openai
LLM_PROVIDER=stub
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_REQUEST_TIMEOUT_S=20

LOG_LEVEL=INFO

# LLM budget guards (per process)
LLM_GLOBAL_DAILY_BUDGET_USD=5.0
LLM_PER_VENDOR_DAILY_BUDGET_USD=1.0

# Optional vendor-scoped signature verification on /webhooks/{vendor_id}
# Example: {"maersk":"shared-secret-1","globalfreightpay":"shared-secret-2"}
WEBHOOK_VENDOR_SECRETS={}
WEBHOOK_SIGNATURE_HEADER=X-Signature
WEBHOOK_SIGNATURE_ENFORCE=false
